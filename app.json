{
  "expo": {
    "name": "Pixiv Novel Reader",
    "slug": "pixiv-novel-reader",
    "version": "2.5.16",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pixivnovelreader",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#08A8F7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.pixivnovelreader",
      "versionCode": 48,
      "permissions": [
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "https",
              "host": "www.pixiv.net",
              "pathPrefix": "/novel/show.php"
            },
            {
              "scheme": "https",
              "host": "pixiv.net",
              "pathPrefix": "/novel/show.php"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#079DF7",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "dark": {
            "backgroundColor": "#063B70",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "novel-updates"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
